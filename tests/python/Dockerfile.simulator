# HnVue Python HAL Simulator Docker Image
# SPEC-TEST-001 Phase 2: Containerized HW simulator testbench

FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy simulator code
COPY simulator/ ./simulator/

# Expose gRPC ports
# 50051: Detector Acquisition Server
# 50052: HVG Control Server
EXPOSE 50051 50052

# Default command runs detector server
CMD ["python", "-m", "simulator.detector_server", "--port", "50051"]
